{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "STSCallerIdentity",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ReadTutorialBucketMetadata",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation",
        "s3:GetBucketTagging"
      ],
      "Resource": "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user"
    },
    {
      "Sid": "ListTutorialBucketPrefixes",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "raw/*",
            "curated/*",
            "training/*",
            "evaluation/*",
            "pipeline/*"
          ]
        }
      }
    },
    {
      "Sid": "ReadWriteTutorialObjects",
      "Effect": "Allow",
      "Action": [
        "s3:AbortMultipartUpload",
        "s3:GetObject",
        "s3:PutObject"
      ],
      "Resource": [
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/raw/*",
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/curated/*",
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/training/*",
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/evaluation/*",
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/pipeline/*"
      ]
    },
    {
      "Sid": "ReadTutorialSageMakerStateInEuWest1",
      "Effect": "Allow",
      "Action": [
        "sagemaker:Describe*",
        "sagemaker:List*"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "eu-west-1"
        }
      }
    },
    {
      "Sid": "ReadTutorialCloudWatchStateInEuWest1",
      "Effect": "Allow",
      "Action": [
        "cloudwatch:Describe*",
        "cloudwatch:Get*",
        "cloudwatch:List*",
        "logs:Describe*",
        "logs:FilterLogEvents",
        "logs:Get*",
        "logs:ListTagsLogGroup",
        "logs:StartQuery",
        "logs:StopQuery"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "eu-west-1"
        }
      }
    },
    {
      "Sid": "CreateAndUpdateTutorialSageMakerResourcesInEuWest1",
      "Effect": "Allow",
      "Action": [
        "sagemaker:AddTags",
        "sagemaker:CreateEndpoint",
        "sagemaker:CreateEndpointConfig",
        "sagemaker:CreateModel",
        "sagemaker:CreatePipeline",
        "sagemaker:CreateTrainingJob",
        "sagemaker:StartPipelineExecution",
        "sagemaker:UpdateEndpoint",
        "sagemaker:UpdatePipeline"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "eu-west-1"
        }
      }
    },
    {
      "Sid": "ApproveTutorialModelPackages",
      "Effect": "Allow",
      "Action": [
        "sagemaker:UpdateModelPackage"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:model-package/titanic-survival-xgboost/*"
    },
    {
      "Sid": "InvokeTutorialEndpoints",
      "Effect": "Allow",
      "Action": [
        "sagemaker:InvokeEndpoint"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:endpoint/titanic-*"
    },
    {
      "Sid": "PassOnlyProjectSageMakerRoles",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": [
        "arn:aws:iam::939122281183:role/titanic-sagemaker-pipeline-*",
        "arn:aws:iam::939122281183:role/titanic-sagemaker-sagemaker-execution-*"
      ],
      "Condition": {
        "StringEquals": {
          "iam:PassedToService": "sagemaker.amazonaws.com"
        }
      }
    }
  ]
}
