{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "STSCallerIdentity",
      "Effect": "Allow",
      "Action": [
        "sts:GetCallerIdentity"
      ],
      "Resource": "*"
    },
    {
      "Sid": "ReadTutorialCleanupStateInEuWest1",
      "Effect": "Allow",
      "Action": [
        "sagemaker:Describe*",
        "sagemaker:List*"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestedRegion": "eu-west-1"
        }
      }
    },
    {
      "Sid": "StopDeleteProjectTrainingJobs",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteTrainingJob",
        "sagemaker:DescribeTrainingJob",
        "sagemaker:StopTrainingJob"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:training-job/titanic-*"
    },
    {
      "Sid": "StopProjectTransformJobs",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DescribeTransformJob",
        "sagemaker:StopTransformJob"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:transform-job/titanic-*"
    },
    {
      "Sid": "DeleteProjectEndpoints",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteEndpoint",
        "sagemaker:DescribeEndpoint"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:endpoint/titanic-*"
    },
    {
      "Sid": "DeleteProjectEndpointConfigs",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteEndpointConfig",
        "sagemaker:DescribeEndpointConfig"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:endpoint-config/titanic-*"
    },
    {
      "Sid": "DeleteProjectModels",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteModel",
        "sagemaker:DescribeModel"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:model/titanic-*"
    },
    {
      "Sid": "DeleteProjectPipelines",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeletePipeline",
        "sagemaker:DescribePipeline"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:pipeline/titanic-*"
    },
    {
      "Sid": "DeleteProjectModelPackages",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteModelPackage",
        "sagemaker:DescribeModelPackage"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:model-package/titanic-survival-xgboost/*"
    },
    {
      "Sid": "DeleteProjectModelPackageGroup",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteModelPackageGroup",
        "sagemaker:DescribeModelPackageGroup"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:model-package-group/titanic-survival-xgboost"
    },
    {
      "Sid": "ReadTutorialBucketMetadata",
      "Effect": "Allow",
      "Action": [
        "s3:GetBucketLocation"
      ],
      "Resource": "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user"
    },
    {
      "Sid": "ListTutorialCleanupPrefixes",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "raw/*",
            "curated/*",
            "training/*",
            "evaluation/*",
            "pipeline/*"
          ]
        }
      }
    },
    {
      "Sid": "DeleteTutorialObjects",
      "Effect": "Allow",
      "Action": [
        "s3:DeleteObject"
      ],
      "Resource": [
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/raw/*",
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/curated/*",
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/training/*",
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/evaluation/*",
        "arn:aws:s3:::titanic-data-bucket-939122281183-data-science-user/pipeline/*"
      ]
    }
  ]
}
