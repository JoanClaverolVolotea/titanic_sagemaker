{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "StopProjectTransformJobs",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DescribeTransformJob",
        "sagemaker:StopTransformJob"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:transform-job/titanic-*"
    },
    {
      "Sid": "DeleteProjectEndpoints",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteEndpoint",
        "sagemaker:DescribeEndpoint"
      ],
      "Resource": [
        "arn:aws:sagemaker:eu-west-1:939122281183:endpoint/titanic-*",
        "arn:aws:sagemaker:eu-west-1:939122281183:endpoint/titanic-survival-*"
      ]
    },
    {
      "Sid": "DeleteProjectEndpointConfigs",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteEndpointConfig",
        "sagemaker:DescribeEndpointConfig"
      ],
      "Resource": [
        "arn:aws:sagemaker:eu-west-1:939122281183:endpoint-config/titanic-*",
        "arn:aws:sagemaker:eu-west-1:939122281183:endpoint-config/titanic-survival-*"
      ]
    },
    {
      "Sid": "DeleteProjectModels",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteModel",
        "sagemaker:DescribeModel"
      ],
      "Resource": [
        "arn:aws:sagemaker:eu-west-1:939122281183:model/titanic-*",
        "arn:aws:sagemaker:eu-west-1:939122281183:model/titanic-survival-*"
      ]
    },
    {
      "Sid": "DeleteProjectPipelines",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeletePipeline",
        "sagemaker:DescribePipeline"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:pipeline/titanic-*"
    },
    {
      "Sid": "DeleteProjectModelPackages",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteModelPackage",
        "sagemaker:DescribeModelPackage"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:model-package/titanic-survival-xgboost/*"
    },
    {
      "Sid": "DeleteProjectModelPackageGroup",
      "Effect": "Allow",
      "Action": [
        "sagemaker:DeleteModelPackageGroup",
        "sagemaker:DescribeModelPackageGroup"
      ],
      "Resource": "arn:aws:sagemaker:eu-west-1:939122281183:model-package-group/titanic-survival-xgboost"
    }
  ]
}
